<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.poo.simuladorinmobiliaria.viewController.CompradorViewController"
      prefWidth="1060" prefHeight="740">

    <!-- Barra superior -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: #1B5E20; -fx-padding: 12;">
        <Label text="InmoSmart  —  Panel Comprador"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblNombreUsuario"
               style="-fx-text-fill: #C8E6C9; -fx-font-size: 13;"/>
        <Button text="Cerrar sesion" onAction="#cerrarSesionAction"
                style="-fx-background-color: white; -fx-text-fill: #1B5E20; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- TAB 1: Buscar Catálogo -->
        <Tab text="Buscar Catalogo">
            <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS">

                <!-- PANEL IZQUIERDO: filtros + tabla catalogo -->
                <VBox spacing="10" style="-fx-padding: 14;">
                    <Label text="Buscar en el Catalogo"
                           style="-fx-font-size: 15; -fx-font-weight: bold;"/>

                    <GridPane hgap="10" vgap="8">
                        <Label text="Ciudad:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="comboCiudad" promptText="Todas las ciudades"
                                  prefWidth="170"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="comboTipo" prefWidth="170"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Precio min:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtPrecioMin" promptText="0" prefWidth="170"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Precio max:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtPrecioMax" promptText="Sin limite" prefWidth="170"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Area min (m2):" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtAreaMin" promptText="0" prefWidth="170"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </GridPane>

                    <HBox spacing="8">
                        <Button text="Buscar" onAction="#buscarAction"
                                style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 90;"/>
                        <Button text="Limpiar" onAction="#limpiarFiltrosAction"
                                style="-fx-cursor: hand; -fx-pref-width: 80;"/>
                    </HBox>

                    <Label fx:id="lblMsgBusqueda" text="" style="-fx-font-size: 12; -fx-text-fill: #444;"/>

                    <TableView fx:id="tablaCatalogo" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCatCodigo"    text="Codigo"     prefWidth="90"/>
                            <TableColumn fx:id="colCatDireccion" text="Direccion"  prefWidth="160"/>
                            <TableColumn fx:id="colCatCiudad"    text="Ciudad"     prefWidth="90"/>
                            <TableColumn fx:id="colCatTipo"      text="Tipo"       prefWidth="100"/>
                            <TableColumn fx:id="colCatPrecio"    text="Precio"     prefWidth="120"/>
                            <TableColumn fx:id="colCatArea"      text="Area (m2)"  prefWidth="80"/>
                        </columns>
                    </TableView>

                    <HBox spacing="8">
                        <Label text="Haz clic en una fila para auto-rellenar el codigo al ofertar."
                               style="-fx-font-size: 11; -fx-text-fill: #888;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Guardar en Favoritos" onAction="#agregarFavoritoAction"
                                style="-fx-background-color: #E65100; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 11;"/>
                    </HBox>

                    <!-- Visor de imágenes / carrusel -->
                    <Separator/>
                    <VBox spacing="5" style="-fx-padding: 2 0 0 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Fotos del inmueble"
                                   style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #1B5E20;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Ver Galeria" onAction="#verGaleriaAction"
                                    style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-size: 11; -fx-cursor: hand; -fx-padding: 4 10; -fx-background-radius: 4;"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER">
                            <Button text="&lt;" onAction="#imagenAnteriorAction"
                                    style="-fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-color: #2E7D32; -fx-text-fill: white; -fx-background-radius: 4;"
                                    prefWidth="26" prefHeight="160"/>
                            <ImageView fx:id="imgVistaPrevia" fitWidth="280" fitHeight="175"
                                       preserveRatio="true"
                                       style="-fx-border-color: #bbb; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 6, 0, 0, 2);"/>
                            <Button text="&gt;" onAction="#imagenSiguienteAction"
                                    style="-fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-color: #2E7D32; -fx-text-fill: white; -fx-background-radius: 4;"
                                    prefWidth="26" prefHeight="160"/>
                        </HBox>
                        <HBox fx:id="hboxThumbs" spacing="5" alignment="CENTER_LEFT"/>
                        <Label fx:id="lblContadorImagenes" text="Selecciona un inmueble para ver sus fotos"
                               style="-fx-font-size: 11; -fx-text-fill: #888;" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- PANEL DERECHO: sugerencias + realizar oferta -->
                <VBox spacing="10" style="-fx-padding: 14;">

                    <Label text="Mis Sugerencias"
                           style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                    <Button text="Refrescar sugerencias" onAction="#cargarSugerenciasAction"
                            style="-fx-cursor: hand;"/>
                    <TableView fx:id="tablaSugerencias" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSugDireccion" text="Direccion" prefWidth="160"/>
                            <TableColumn fx:id="colSugPrecio"    text="Precio"    prefWidth="130"/>
                            <TableColumn fx:id="colSugTipo"      text="Tipo"      prefWidth="100"/>
                        </columns>
                    </TableView>

                    <Separator/>

                    <Label text="Realizar Oferta"
                           style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                    <GridPane hgap="10" vgap="10">
                        <Label text="Codigo publicacion:"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtCodigoPublicacion"
                                   promptText="Selecciona fila o pega el codigo"
                                   prefWidth="220"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Monto ofertado (COP):"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtMontoOferta"
                                   promptText="Ej: 340000000"
                                   prefWidth="220"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>
                    <Button text="Enviar Oferta" onAction="#ofertarAction"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 140;"/>
                    <Label fx:id="lblMsgOferta" text="" wrapText="true"
                           style="-fx-font-size: 13;"/>
                </VBox>

            </SplitPane>
        </Tab>

        <!-- TAB 2: Mis Ofertas -->
        <Tab text="Mis Ofertas">
            <VBox spacing="10" style="-fx-padding: 14;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Estado de Mis Ofertas"
                           style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Refrescar" onAction="#refrescarOfertasAction"
                            style="-fx-cursor: hand;"/>
                </HBox>
                <Label text="Aqui puedes ver el estado actual de todas las ofertas que has enviado."
                       style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <TableView fx:id="tablaOfertasComprador" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMisOfInmueble" text="Inmueble"   prefWidth="220"/>
                        <TableColumn fx:id="colMisOfCiudad"   text="Ciudad"     prefWidth="120"/>
                        <TableColumn fx:id="colMisOfMonto"    text="Monto"      prefWidth="150"/>
                        <TableColumn fx:id="colMisOfEstado"   text="Estado"     prefWidth="130"/>
                        <TableColumn fx:id="colMisOfFecha"    text="Fecha"      prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- TAB 3: Notificaciones -->
        <Tab text="Notificaciones">
            <VBox spacing="10" style="-fx-padding: 14;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Mis Notificaciones"
                           style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Refrescar" onAction="#refrescarNotificacionesAction"
                            style="-fx-cursor: hand;"/>
                </HBox>
                <TableView fx:id="tablaNotificComprador" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNotTitulo"    text="Titulo"    prefWidth="180"/>
                        <TableColumn fx:id="colNotContenido" text="Mensaje"   prefWidth="340"/>
                        <TableColumn fx:id="colNotTipo"      text="Tipo"      prefWidth="160"/>
                        <TableColumn fx:id="colNotFecha"     text="Fecha"     prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- TAB 4: Mis Transacciones -->
        <Tab text="Mis Transacciones">
            <VBox spacing="10" style="-fx-padding: 14;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Historial de Transacciones Completadas"
                           style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Refrescar" onAction="#refrescarTransaccionesAction"
                            style="-fx-cursor: hand;"/>
                </HBox>
                <Label text="Aqui aparecen los inmuebles que compraste o arrendaste."
                       style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <TableView fx:id="tablaTransaccComprador" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTransCInmueble" text="Inmueble"   prefWidth="200"/>
                        <TableColumn fx:id="colTransCCiudad"   text="Ciudad"     prefWidth="120"/>
                        <TableColumn fx:id="colTransCValor"    text="Valor Final" prefWidth="150"/>
                        <TableColumn fx:id="colTransCTipo"     text="Tipo"       prefWidth="100"/>
                        <TableColumn fx:id="colTransCFecha"    text="Fecha"      prefWidth="240"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- TAB 5: Mis Favoritos -->
        <Tab text="Mis Favoritos">
            <VBox spacing="10" style="-fx-padding: 14;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Inmuebles Guardados como Favoritos"
                           style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Eliminar seleccionado" onAction="#eliminarFavoritoAction"
                            style="-fx-background-color: #B71C1C; -fx-text-fill: white; -fx-cursor: hand;"/>
                </HBox>
                <Label text="Selecciona un inmueble del Catalogo y pulsa 'Guardar en Favoritos' para agregarlo aqui."
                       style="-fx-font-size: 12; -fx-text-fill: #666;" wrapText="true"/>
                <Label fx:id="lblMsgFavoritos" text="" style="-fx-font-size: 12;"/>
                <TableView fx:id="tablaFavoritos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFavDireccion" text="Direccion"  prefWidth="220"/>
                        <TableColumn fx:id="colFavCiudad"    text="Ciudad"     prefWidth="120"/>
                        <TableColumn fx:id="colFavPrecio"    text="Precio"     prefWidth="150"/>
                        <TableColumn fx:id="colFavTipo"      text="Tipo"       prefWidth="110"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- TAB 6: Mi Perfil -->
        <Tab text="Mi Perfil">
            <VBox spacing="16" style="-fx-padding: 24;">
                <Label text="Actualizar Mis Datos de Contacto"
                       style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                <Label text="Deja en blanco los campos que no deseas cambiar."
                       style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Separator/>
                <GridPane hgap="12" vgap="12">
                    <Label text="Nombre completo:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="fPerfilNombre" prefWidth="280"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Telefono:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="fPerfilTelefono" prefWidth="280"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Correo electronico:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="fPerfilEmail" prefWidth="280"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Nueva contrasena:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="fPerfilPassword" promptText="Dejar vacio para no cambiar"
                                   prefWidth="280"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
                <Button text="Guardar Cambios" onAction="#guardarPerfilAction"
                        style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Label fx:id="lblMsgPerfil" text="" wrapText="true"
                       style="-fx-font-size: 13;"/>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
