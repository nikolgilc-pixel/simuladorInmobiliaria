<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.poo.simuladorinmobiliaria.controller.LoginController"
      prefWidth="900" prefHeight="600">

    <!-- ═══ MITAD IZQUIERDA — Imagen desde classpath ═══ -->
    <StackPane prefWidth="450" prefHeight="600">

        <ImageView fitWidth="450" fitHeight="600"
                   preserveRatio="false" smooth="true">
            <image>
                <Image url="@login-fondo.jpg"/>
            </image>
        </ImageView>

        <!-- Overlay sutil para dar profundidad -->
        <Region style="-fx-background-color: rgba(10,30,60,0.15);"/>

    </StackPane>

    <!-- ═══ MITAD DERECHA — Formulario original sin cambios ═══ -->
    <VBox alignment="CENTER" spacing="16"
          prefWidth="450" prefHeight="600"
          style="-fx-background-color: #F5F7FA;">
        <padding>
            <Insets top="50" right="70" bottom="50" left="70"/>
        </padding>

        <Label text="InmoSmart"
               style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
        <Label text="Sistema de Simulacion Inmobiliaria"
               style="-fx-font-size: 13; -fx-text-fill: #666;"/>

        <Separator/>

        <GridPane hgap="10" vgap="12" alignment="CENTER">
            <Label text="Correo electronico:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                   style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtEmail" promptText="usuario@correo.com"
                       prefWidth="220"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Contrasena:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                   style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="txtPassword" promptText="Contrasena"
                           prefWidth="220"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>

        <Button text="Ingresar" onAction="#ingresarAction"
                prefWidth="220"
                style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Label fx:id="lblError" text=""
               style="-fx-text-fill: #C62828; -fx-font-size: 12;"
               visible="false" wrapText="true"/>

        <Separator/>

        <Hyperlink text="¿No tienes cuenta? Registrate como Comprador"
                   onAction="#irARegistroAction"
                   style="-fx-font-size: 12; -fx-text-fill: #1565C0;"/>

        <Label text="Admin: admin@inmosmart.com / admin123  |  Vendedor: carlos@test.com / 1234  |  Comprador: maria@test.com / 1234"
               style="-fx-font-size: 10; -fx-text-fill: #999;" wrapText="true"/>
    </VBox>

</HBox>
