<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.poo.simuladorinmobiliaria.viewController.RegistroCompradorViewController"
      alignment="CENTER" spacing="14"
      prefWidth="500" prefHeight="600"
      style="-fx-background-color: #F5F7FA;">
    <padding>
        <Insets top="40" right="60" bottom="40" left="60"/>
    </padding>

    <Label text="InmoSmart — Registro de Comprador"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
    <Label text="Completa tus datos para crear tu cuenta"
           style="-fx-font-size: 12; -fx-text-fill: #666;"/>

    <Separator/>

    <GridPane hgap="12" vgap="12" alignment="CENTER">
        <Label text="Nombre completo (*)" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="fNombre" promptText="Tu nombre completo" prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Telefono" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="fTelefono" promptText="+573XXXXXXXXX" prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Correo electronico (*)" GridPane.columnIndex="0" GridPane.rowIndex="2"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="fEmail" promptText="tu@correo.com" prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Contrasena (*)" GridPane.columnIndex="0" GridPane.rowIndex="3"
               style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="fPassword" promptText="Minimo 4 caracteres" prefWidth="240"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Presupuesto (COP)" GridPane.columnIndex="0" GridPane.rowIndex="4"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="fPresupuesto" promptText="Ej: 500000000" prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Ciudad de interes (*)" GridPane.columnIndex="0" GridPane.rowIndex="5"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="fCiudadInteres" promptText="Ej: Bogota" prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Tipo inmueble interes (*)" GridPane.columnIndex="0" GridPane.rowIndex="6"
               style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="comboTipoInteres" prefWidth="240"
                  GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <Label text="Area minima (m2)" GridPane.columnIndex="0" GridPane.rowIndex="7"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="fAreaMin" promptText="Ej: 50" prefWidth="240"
                   GridPane.columnIndex="1" GridPane.rowIndex="7"/>
    </GridPane>

    <Label fx:id="lblMsg" text="" wrapText="true"
           style="-fx-font-size: 12;" maxWidth="380"/>

    <HBox spacing="12" alignment="CENTER">
        <Button text="Crear Cuenta" onAction="#registrarAction"
                style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 140;"/>
        <Button text="Volver al Login" onAction="#volverAction"
                style="-fx-cursor: hand; -fx-pref-width: 140;"/>
    </HBox>

    <Label text="(*) Campos obligatorios"
           style="-fx-font-size: 10; -fx-text-fill: #999;"/>
</VBox>
